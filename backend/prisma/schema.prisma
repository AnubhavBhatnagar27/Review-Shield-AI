generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Review {

  id               String   @id @default(cuid())

  productCategory  String
  overallRating    Float
  reviewText       String

  fakeOrReal       String
  sentiment        String

  createdAt        DateTime @default(now())
}